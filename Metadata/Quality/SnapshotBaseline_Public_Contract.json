{
  "contractId": "SC-023-PUBLIC-V1",
  "contractVersion": 1,
  "releaseState": "IMPLEMENTED_ACTIONS_GATE",
  "minimumSqlServerMajorVersion": 15,
  "targetSqlServerMajorVersions": [15, 16, 17],
  "packageBoundary": {
    "statelessCoreInstaller": "Code/Install/Install_All.sql",
    "frameworkInstaller": "Code/Install/Install_SnapshotBaseline_Framework.sql",
    "targetInstaller": "Code/Install/Install_SnapshotBaseline_Target.sql",
    "standaloneBuilder": "Code/Install/Build-SnapshotBaselineInstallers.ps1",
    "generatedFrameworkInstaller": "Code/Install/generated/Install_SnapshotBaseline_Framework.generated.sql",
    "generatedTargetInstaller": "Code/Install/generated/Install_SnapshotBaseline_Target.generated.sql",
    "coreInstallsPackage": false,
    "createsDatabase": false,
    "createsRightsOrPrincipals": false,
    "createsSchedulerObjects": false
  },
  "publicProcedures": [
    "monitor.USP_ConfigureSnapshotTarget",
    "monitor.USP_RunSnapshotCollectionCycle",
    "monitor.USP_PurgeSnapshotData"
  ],
  "collector": {
    "code": "PERFORMANCE_COUNTERS",
    "sourceProcedure": "monitor.USP_PerformanceCounters",
    "sampleSeconds": 0,
    "defaultIntervalSeconds": 30,
    "defaultMaxRows": 1000,
    "payloadDefaultEnabled": false
  },
  "retentionDefaults": {
    "rawDays": 14,
    "payloadDays": 7,
    "rollupDaysReserved": 180,
    "softBudgetMb": 10240,
    "purgeIntervalMinutes": 60,
    "purgeBatchRows": 10000,
    "budgetAction": "PURGE_EXPIRED_THEN_STOP"
  },
  "schedulerTypes": ["MANUAL", "EXTERNAL", "SQL_AGENT"],
  "statusCodes": [
    "AVAILABLE",
    "PARTIAL",
    "AVAILABLE_LIMITED",
    "SKIPPED_NOT_DUE",
    "SKIPPED_CONCURRENT",
    "DISABLED",
    "TARGET_UNAVAILABLE",
    "DENIED_PERMISSION",
    "STOPPED_SIZE_BUDGET",
    "INVALID_PARAMETER",
    "ERROR_HANDLED"
  ],
  "invariants": [
    "No source read occurs for disabled, not-due, concurrent, unavailable-target or stopped-budget cycles.",
    "Missing or partial evidence never becomes a fabricated numeric zero.",
    "Reset epochs remain stable for one SQL Server start and never span a restart.",
    "Purge deletes expired child rows first and never deletes unexpired evidence to satisfy the soft budget.",
    "Optional payload persistence is lossless, versioned, compressed and hash-bound.",
    "Repository fixtures and failure summaries contain synthetic generic values only."
  ],
  "runtimeContract": "Code/Tests/Integration/195_SnapshotBaseline_Runtime_Contract.sql",
  "matrixWorkflow": ".github/workflows/snapshot-baseline-release-gate.yml"
}
