{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LAB-001 configuration contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "SchemaVersion",
    "DataClassification",
    "ExecutionMode",
    "AllowedExecutionModes",
    "SqlVersionPriority",
    "ContainerEngine",
    "ContainerImageLogicalIds",
    "AcceptSqlServerEula",
    "ResourceProfile",
    "StorageRoleBindings",
    "NetworkPolicy",
    "Retention",
    "Timeouts"
  ],
  "properties": {
    "SchemaVersion": {
      "const": "1.0"
    },
    "DataClassification": {
      "const": "SYNTHETIC_EXAMPLE"
    },
    "ExecutionMode": {
      "enum": [
        "AUTO",
        "WINDOWS_SINGLE_HOST",
        "LINUX_NATIVE",
        "DISTRIBUTED"
      ]
    },
    "AllowedExecutionModes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "WINDOWS_SINGLE_HOST",
          "LINUX_NATIVE",
          "DISTRIBUTED"
        ]
      }
    },
    "SqlVersionPriority": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          2019,
          2022,
          2025
        ]
      }
    },
    "ContainerEngine": {
      "enum": [
        "DOCKER",
        "PODMAN"
      ]
    },
    "ContainerImageLogicalIds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "2019",
        "2022",
        "2025"
      ],
      "properties": {
        "2019": {
          "$ref": "#/$defs/logicalReference"
        },
        "2022": {
          "$ref": "#/$defs/logicalReference"
        },
        "2025": {
          "$ref": "#/$defs/logicalReference"
        }
      }
    },
    "AcceptSqlServerEula": {
      "const": false
    },
    "ResourceProfile": {
      "enum": [
        "Compact",
        "Standard",
        "Stress"
      ]
    },
    "StorageRoleBindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "IMAGE_CACHE",
        "ACTIVE_VM",
        "EPHEMERAL_DATA",
        "FAULT_TARGET"
      ],
      "properties": {
        "IMAGE_CACHE": {
          "$ref": "#/$defs/logicalReference"
        },
        "ACTIVE_VM": {
          "$ref": "#/$defs/logicalReference"
        },
        "EPHEMERAL_DATA": {
          "$ref": "#/$defs/logicalReference"
        },
        "FAULT_TARGET": {
          "$ref": "#/$defs/logicalReference"
        }
      }
    },
    "NetworkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "PrivateRangeReference",
        "RejectRouteCollision",
        "AllowExternalLabDataNetwork"
      ],
      "properties": {
        "PrivateRangeReference": {
          "$ref": "#/$defs/logicalReference"
        },
        "RejectRouteCollision": {
          "const": true
        },
        "AllowExternalLabDataNetwork": {
          "const": false
        }
      }
    },
    "Retention": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "MaximumCacheAgeDays",
        "MaximumArtifactAgeDays"
      ],
      "properties": {
        "MaximumCacheAgeDays": {
          "type": "integer",
          "minimum": 0
        },
        "MaximumArtifactAgeDays": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "Timeouts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "PreflightSeconds",
        "SetupSeconds",
        "ObserveSeconds",
        "CleanupSeconds"
      ],
      "properties": {
        "PreflightSeconds": {
          "$ref": "#/$defs/positiveInteger"
        },
        "SetupSeconds": {
          "$ref": "#/$defs/positiveInteger"
        },
        "ObserveSeconds": {
          "$ref": "#/$defs/positiveInteger"
        },
        "CleanupSeconds": {
          "$ref": "#/$defs/positiveInteger"
        }
      }
    }
  },
  "$defs": {
    "logicalReference": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Z0-9_]+$"
    },
    "positiveInteger": {
      "type": "integer",
      "minimum": 1
    }
  }
}
