{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LAB-001 Welle 5 Hyper-V image-pipeline contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "SchemaVersion",
    "WaveId",
    "ContractStatus",
    "RuntimeStatus",
    "DataClassification",
    "BuilderAdapters",
    "ParentMatrix",
    "PipelineStages",
    "ChildResetContract",
    "ExternalEvidenceGates"
  ],
  "properties": {
    "SchemaVersion": {
      "const": "1.0"
    },
    "WaveId": {
      "const": "LAB-001-WAVE5"
    },
    "ContractStatus": {
      "const": "VALIDATED_FOUNDATION"
    },
    "RuntimeStatus": {
      "const": "NOT_EXECUTED"
    },
    "DataClassification": {
      "const": "SYNTHETIC"
    },
    "BuilderAdapters": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "$ref": "#/$defs/builderAdapter"
      }
    },
    "ParentMatrix": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/parentMatrixEntry"
      }
    },
    "PipelineStages": {
      "type": "array",
      "minItems": 11,
      "maxItems": 11,
      "items": {
        "$ref": "#/$defs/pipelineStage"
      }
    },
    "ChildResetContract": {
      "$ref": "#/$defs/childResetContract"
    },
    "ExternalEvidenceGates": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "$ref": "#/$defs/evidenceGate"
      }
    }
  },
  "$defs": {
    "builderAdapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "AdapterId",
        "SupportLevel",
        "ExecutionStatus",
        "LocalExecutableBindingRequired"
      ],
      "properties": {
        "AdapterId": {
          "enum": [
            "NATIVE_POWERSHELL",
            "PACKER"
          ]
        },
        "SupportLevel": {
          "enum": [
            "REQUIRED",
            "OPTIONAL"
          ]
        },
        "ExecutionStatus": {
          "const": "NOT_EXECUTED"
        },
        "LocalExecutableBindingRequired": {
          "type": "boolean"
        }
      }
    },
    "parentMatrixEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ParentLogicalId",
        "SqlVersion",
        "SqlMajorVersion",
        "WindowsMediaLogicalId",
        "SqlMediaLogicalId",
        "ParentState",
        "ParentImmutable",
        "AllowInPlaceMutation",
        "ChecksumPolicy",
        "OutputPolicy",
        "GuestManagementChannel"
      ],
      "properties": {
        "ParentLogicalId": {
          "type": "string",
          "pattern": "^W5-WINCORE-SQL(2019|2022|2025)$"
        },
        "SqlVersion": {
          "enum": [
            "2019",
            "2022",
            "2025"
          ]
        },
        "SqlMajorVersion": {
          "enum": [
            15,
            16,
            17
          ]
        },
        "WindowsMediaLogicalId": {
          "const": "WINDOWS_SERVER_CORE"
        },
        "SqlMediaLogicalId": {
          "enum": [
            "SQL_SERVER_2019_DEVELOPER_WINDOWS",
            "SQL_SERVER_2022_DEVELOPER_WINDOWS",
            "SQL_SERVER_2025_DEVELOPER_WINDOWS"
          ]
        },
        "ParentState": {
          "const": "UNBUILT_EXAMPLE"
        },
        "ParentImmutable": {
          "const": true
        },
        "AllowInPlaceMutation": {
          "const": false
        },
        "ChecksumPolicy": {
          "const": "SHA256_REQUIRED"
        },
        "OutputPolicy": {
          "const": "LOCAL_IGNORED_ONLY"
        },
        "GuestManagementChannel": {
          "const": "POWERSHELL_DIRECT"
        }
      }
    },
    "pipelineStage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "Ordinal",
        "StageId",
        "MutationClass",
        "ExecutionStatus",
        "RequiredGuards"
      ],
      "properties": {
        "Ordinal": {
          "type": "integer",
          "minimum": 1,
          "maximum": 11
        },
        "StageId": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]+$"
        },
        "MutationClass": {
          "enum": [
            "READ_ONLY",
            "LOCAL_BUILD_STATE",
            "LOCAL_GUEST_STATE",
            "LOCAL_IMAGE_STATE",
            "LOCAL_CHILD_STATE"
          ]
        },
        "ExecutionStatus": {
          "const": "NOT_EXECUTED"
        },
        "RequiredGuards": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]+$"
          }
        }
      }
    },
    "childResetContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ResetMethod",
        "ParentReadOnly",
        "AllowParentMutation",
        "AllowCheckpointAsCanonicalReset",
        "RequireRegisteredObjectIds",
        "AllowNameOnlyDeletion",
        "ChildStateClassification",
        "FailedChildReusePolicy"
      ],
      "properties": {
        "ResetMethod": {
          "const": "NEW_DIFFERENCING_DISK"
        },
        "ParentReadOnly": {
          "const": true
        },
        "AllowParentMutation": {
          "const": false
        },
        "AllowCheckpointAsCanonicalReset": {
          "const": false
        },
        "RequireRegisteredObjectIds": {
          "const": true
        },
        "AllowNameOnlyDeletion": {
          "const": false
        },
        "ChildStateClassification": {
          "const": "LOCAL_RUNTIME_STATE"
        },
        "FailedChildReusePolicy": {
          "const": "DISCARD_AND_RECREATE"
        }
      }
    },
    "evidenceGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "GateId",
        "RequiredPlatform",
        "RequiredCapability",
        "Status",
        "EvidencePolicy"
      ],
      "properties": {
        "GateId": {
          "enum": [
            "LAB-GATE-WAVE5-PARENT-BUILD",
            "LAB-GATE-WAVE5-CHILD-RESET"
          ]
        },
        "RequiredPlatform": {
          "const": "HYPER_V_WINDOWS"
        },
        "RequiredCapability": {
          "enum": [
            "HYPER_V_IMAGE_BUILD",
            "HYPER_V_DIFFERENCING_DISK_RESET"
          ]
        },
        "Status": {
          "const": "NOT_EXECUTED"
        },
        "EvidencePolicy": {
          "const": "SYNTHETIC_SUMMARY_ONLY"
        }
      }
    }
  }
}
