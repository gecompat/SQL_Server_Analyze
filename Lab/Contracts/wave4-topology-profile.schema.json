{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LAB-001 Welle 4 topology contract foundation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "SchemaVersion",
    "WaveId",
    "ContractStatus",
    "RuntimeStatus",
    "DataClassification",
    "TopologyProfiles",
    "ExternalEvidenceGates"
  ],
  "properties": {
    "SchemaVersion": {
      "const": "1.0"
    },
    "WaveId": {
      "const": "LAB-001-WAVE4"
    },
    "ContractStatus": {
      "const": "VALIDATED_FOUNDATION"
    },
    "RuntimeStatus": {
      "const": "NOT_EXECUTED"
    },
    "DataClassification": {
      "const": "SYNTHETIC"
    },
    "TopologyProfiles": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/profile"
      }
    },
    "ExternalEvidenceGates": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "$ref": "#/$defs/gate"
      }
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ProfileId",
        "TopologyId",
        "RequiredRoles",
        "NetworkSegments",
        "ManagementPathIndependent",
        "MaximumSqlNodes",
        "FaultLayer",
        "RuntimeImplementationStatus",
        "CleanupPolicy"
      ],
      "properties": {
        "ProfileId": {
          "type": "string",
          "pattern": "^W4-[A-Z0-9-]+$"
        },
        "TopologyId": {
          "enum": [
            "CTR-SINGLE",
            "CTR-PAIR",
            "CTR-TRIPLE",
            "HV-CROSS-PLATFORM"
          ]
        },
        "RequiredRoles": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          }
        },
        "NetworkSegments": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": [
              "LAB_MANAGEMENT",
              "LAB_DATA",
              "LAB_FAULT"
            ]
          }
        },
        "ManagementPathIndependent": {
          "const": true
        },
        "MaximumSqlNodes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "FaultLayer": {
          "enum": [
            "OPTIONAL",
            "REQUIRED"
          ]
        },
        "RuntimeImplementationStatus": {
          "const": "PLANNED_NOT_IMPLEMENTED"
        },
        "CleanupPolicy": {
          "const": "REGISTERED_OBJECT_IDS_ONLY"
        }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "GateId",
        "RequiredPlatform",
        "RequiredCapability",
        "Status",
        "EvidencePolicy"
      ],
      "properties": {
        "GateId": {
          "enum": [
            "LAB-GATE-WAVE4-MULTI-CONTAINER",
            "LAB-GATE-WAVE4-NETWORK-FAULT"
          ]
        },
        "RequiredPlatform": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "RequiredCapability": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "Status": {
          "const": "NOT_EXECUTED"
        },
        "EvidencePolicy": {
          "const": "SYNTHETIC_SUMMARY_ONLY"
        }
      }
    }
  }
}
