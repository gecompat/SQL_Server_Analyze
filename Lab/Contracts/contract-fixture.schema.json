{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LAB-001 public contract fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "SchemaVersion",
    "ScenarioId",
    "DataClassification",
    "FixtureType",
    "RuntimeEvidenceClaim",
    "RequiredAnalyzer",
    "FindingCode",
    "AcceptedEvidence",
    "RejectedEvidence",
    "Status"
  ],
  "properties": {
    "SchemaVersion": {
      "const": "1.0"
    },
    "ScenarioId": {
      "type": "string",
      "pattern": "^LAB-[A-Z0-9]+-[0-9]{3}$"
    },
    "DataClassification": {
      "const": "PUBLIC_FIXTURE"
    },
    "FixtureType": {
      "type": "string",
      "pattern": "^[A-Z0-9_]+$"
    },
    "RuntimeEvidenceClaim": {
      "const": "NOT_CLAIMED"
    },
    "RequiredAnalyzer": {
      "type": "string",
      "pattern": "^USP_[A-Za-z0-9]+$"
    },
    "FindingCode": {
      "type": "string",
      "pattern": "^[A-Z0-9_]+$"
    },
    "AcceptedEvidence": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "RejectedEvidence": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "Status": {
      "const": "IMPLEMENTED_CONTRACT_FIXTURE"
    }
  }
}
