{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LAB-001 bounded scenario runbook contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "SchemaVersion",
    "ScenarioId",
    "DataClassification",
    "FixedSeed",
    "SqlVersions",
    "RuntimeAction",
    "PrimaryAnalyzer",
    "FindingCode",
    "WorkerCount",
    "WorkerStartLeadSeconds",
    "WorkerTimeoutSeconds",
    "ScenarioTimeoutSeconds",
    "AllowedWorkerExitCodes",
    "ResetPolicy"
  ],
  "properties": {
    "SchemaVersion": {
      "const": "1.0"
    },
    "ScenarioId": {
      "type": "string",
      "pattern": "^LAB-[A-Z0-9]+-[0-9]{3}$"
    },
    "DataClassification": {
      "enum": [
        "SYNTHETIC",
        "PUBLIC_FIXTURE"
      ]
    },
    "FixedSeed": {
      "const": 1701
    },
    "SqlVersions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          2019,
          2022,
          2025
        ]
      }
    },
    "RuntimeAction": {
      "enum": [
        "SQL_ONLY",
        "CONTAINER_RESTART",
        "CONTRACT_FIXTURE"
      ]
    },
    "PrimaryAnalyzer": {
      "type": "string",
      "pattern": "^USP_[A-Za-z0-9]+$"
    },
    "FindingCode": {
      "type": "string",
      "pattern": "^[A-Z0-9_]+$"
    },
    "WorkerCount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 8
    },
    "WorkerStartLeadSeconds": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    },
    "WorkerTimeoutSeconds": {
      "type": "integer",
      "minimum": 10,
      "maximum": 120
    },
    "ScenarioTimeoutSeconds": {
      "type": "integer",
      "minimum": 30,
      "maximum": 600
    },
    "AllowedWorkerExitCodes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "integer",
        "minimum": 0,
        "maximum": 255
      }
    },
    "ResetPolicy": {
      "const": "EXACT_SYNTHETIC_SCOPE"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "RuntimeAction": {
            "const": "CONTRACT_FIXTURE"
          }
        }
      },
      "then": {
        "properties": {
          "DataClassification": {
            "const": "PUBLIC_FIXTURE"
          },
          "WorkerCount": {
            "const": 0
          }
        }
      },
      "else": {
        "properties": {
          "DataClassification": {
            "const": "SYNTHETIC"
          }
        }
      }
    }
  ]
}
